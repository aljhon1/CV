{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.6.0"
    },
    "*.php": {
      "runtime": "vercel-php@0.6.0"
    }
  },
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/process.php",
      "dest": "/process.php"
    },
    {
      "src": "/style.css",
      "dest": "/style.css"
    }
  ]
}
